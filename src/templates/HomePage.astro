---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import FlowMotif from '../components/FlowMotif.astro';
import { getCopy } from '../i18n/copy';
import { pathFor, type Locale, withBase } from '../i18n/utils';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const t = getCopy(locale);
const quickTags =
  locale === 'zh'
    ? ['#在场', '#轻结构', '#数字健康', '#ADHD友好', '#反成瘾']
    : ['#presence', '#gentle-structure', '#digital-wellbeing', '#ADHD-friendly', '#anti-addictive'];
const appMotifs: Array<'wave' | 'rings' | 'breathe'> = ['breathe', 'wave', 'rings', 'wave'];
---

<BaseLayout title={t.meta.siteName} description={t.meta.description} locale={locale} path={path}>
  <section class="hero hero-v2 shell">
    <div class="hero-copy">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1>{t.hero.title}</h1>
      <p class="lead">{t.hero.tagline}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={withBase(pathFor(locale, 'apps'))}>{t.hero.primaryCta}</a>
        <a class="btn btn-secondary" href={`#${t.story.id}`}>{t.hero.secondaryCta}</a>
      </div>
      <p class="calm-note">{t.hero.calmNote}</p>
    </div>
    <div class="hero-board" aria-label={locale === 'zh' ? '品牌方向总览' : 'Brand direction overview'}>
      <article class="hero-tile hero-tile-art">
        <FlowMotif kind="wave" />
        <FlowMotif kind="rings" />
      </article>
      <article class="hero-tile">
        <p class="tile-kicker">{locale === 'zh' ? '正在构建' : 'Building now'}</p>
        <h3>{t.apps.items[0].name}</h3>
        <p>{t.apps.items[0].oneLine}</p>
      </article>
      <article class="hero-tile">
        <p class="tile-kicker">{locale === 'zh' ? '探索方向' : 'Focus tags'}</p>
        <div class="tag-row">
          {quickTags.slice(0, 4).map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      </article>
    </div>
  </section>

  <section class="shell story" id={t.story.id}>
    <div class="section-intro">
      <p class="eyebrow">{locale === 'zh' ? '品牌故事' : 'Brand Story'}</p>
      <h2>{t.story.title}</h2>
      <p>{t.story.intro}</p>
    </div>
    <div class="story-grid">
      {t.story.blocks.slice(0, 3).map((block, index) => (
        <article class="story-block card">
          <p class="story-index">{String(index + 1).padStart(2, '0')}</p>
          <h3>{block.title}</h3>
          <p>{block.body[0]}</p>
        </article>
      ))}
    </div>
    <blockquote class="quote card">
      <p>{t.story.quote}</p>
    </blockquote>
  </section>

  <section class="shell">
    <div class="section-intro">
      <p class="eyebrow">{locale === 'zh' ? '设计原则' : 'Principles'}</p>
      <h2>{t.principles.title}</h2>
      <p>{t.principles.intro}</p>
    </div>
    <div class="principle-grid">
      {t.principles.items.map((item) => (
        <article class="card principle-card">
          <p class="principle-icon" aria-hidden="true">{item.icon}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell" aria-labelledby="apps-showcase-title">
    <div class="section-intro">
      <p class="eyebrow">{locale === 'zh' ? '产品方向' : 'Products'}</p>
      <h2 id="apps-showcase-title">{t.apps.title}</h2>
      <p>{t.apps.intro}</p>
    </div>
    <div class="app-grid app-grid-showcase">
      {t.apps.items.map((app, index) => (
        <AppCard
          app={app}
          locale={locale}
          badgeComing={t.apps.badgeComing}
          badgeProgress={t.apps.badgeProgress}
          learnMore={t.apps.learnMore}
          variant={index === 0 ? 'featured' : 'default'}
          motif={appMotifs[index] ?? 'wave'}
        />
      ))}
    </div>
  </section>
</BaseLayout>
