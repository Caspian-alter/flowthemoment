---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductVisual from '../components/ProductVisual.astro';
import { getCopy } from '../i18n/copy';
import { pathFor, type Locale, withBase } from '../i18n/utils';
import { getProfilePath } from '../i18n/app-profiles';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const t = getCopy(locale);
const homeApps = t.apps.items.filter((app) => app.id !== 'sunshine-breath');
const releasedApps = homeApps.filter((app) => app.status === 'released');
const featuredApps = releasedApps.length >= 2 ? releasedApps.slice(0, 2) : homeApps.slice(0, 2);
const featuredIds = new Set(featuredApps.map((app) => app.id));
const spotlightApps = homeApps.filter((app) => !featuredIds.has(app.id)).slice(0, 3);
const homeTitle =
  locale === 'zh'
    ? '轻想法与成瘾猫已发布 | Flow the Moment · 温柔的在场与数字健康工具'
    : 'Light Ideas and Craving Cat are live | Flow the Moment · gentle tools for presence';
const homeDescription =
  locale === 'zh'
    ? 'Flow the Moment：轻想法与成瘾猫已经发布。这里是一个围绕在场、注意力与数字健康的双语产品工作室。'
    : 'Flow the Moment: Light Ideas and Craving Cat are now live. A bilingual studio for presence, attention, and digital wellbeing.';
const siteOrigin = Astro.site?.toString() ?? 'https://flowthemoment.com';
const homeUrl = new URL(withBase(pathFor(locale, 'home')), siteOrigin).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: locale === 'zh' ? 'Flow the Moment / 流动此刻' : 'Flow the Moment',
    url: homeUrl,
    inLanguage: locale === 'zh' ? 'zh-CN' : 'en'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Flow the Moment',
    url: siteOrigin,
    description: t.meta.description
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
      name: locale === 'zh' ? '精选产品' : 'Featured products',
      itemListElement: homeApps.map((app, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: app.name,
        url: new URL(withBase(getProfilePath(locale, app.id) ?? pathFor(locale, 'apps')), siteOrigin).toString()
    }))
  }
];
const quickTags =
  locale === 'zh'
    ? ['#在场', '#轻结构', '#数字健康', '#ADHD友好', '#反成瘾']
    : ['#presence', '#gentle-structure', '#digital-wellbeing', '#ADHD-friendly', '#anti-addictive'];
const appMotifs: Array<'cat' | 'wave' | 'rings' | 'breathe'> = ['cat', 'breathe', 'wave', 'rings'];
const labels =
  locale === 'zh'
    ? {
        story: '品牌故事',
        quote: '立场',
        principles: '原则',
      products: '产品',
      focus: '关心什么',
      leading: '已发布',
      collection: '更多产品'
    }
  : {
        story: 'Brand Story',
        quote: 'Position',
        principles: 'Principles',
      products: 'Products',
      focus: 'What we care about',
      leading: 'Released',
      collection: 'More from the studio'
    };
const spotlightMotifs: Array<'breathe' | 'wave' | 'rings'> = ['breathe', 'wave', 'rings'];
const heroVisualMotif = (appId: string): 'cat' | 'wave' | 'rings' | 'breathe' => {
  if (appId === 'craving-cat') return 'cat';
  if (appId === 'light-ideas') return 'breathe';
  if (appId === 'anchor-now') return 'wave';
  return 'rings';
};
const badgeFor = (status: 'coming' | 'progress' | 'released') =>
  status === 'released' ? t.apps.badgeReleased : status === 'progress' ? t.apps.badgeProgress : t.apps.badgeComing;
---

<BaseLayout title={homeTitle} description={homeDescription} locale={locale} path={path} jsonLd={jsonLd}>
  <section class="hero hero-v2 shell editorial-hero">
    <div class="hero-copy hero-copy-editorial">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1>{t.hero.title}</h1>
      <p class="lead">{t.hero.tagline}</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href={withBase(pathFor(locale, 'apps'))}>{t.hero.primaryCta}</a>
        <a class="btn btn-secondary" href={`#${t.story.id}`}>{t.hero.secondaryCta}</a>
      </div>
      <p class="calm-note">{t.hero.calmNote}</p>
      <div class="hero-footnote">
        <span>{labels.focus}</span>
        <div class="tag-row">
          {quickTags.slice(0, 4).map((tag) => (
            <span class="tag-pill">{tag}</span>
          ))}
        </div>
      </div>
    </div>
    <div class="hero-stage" aria-label={locale === 'zh' ? '产品展板' : 'Product board'}>
      <div class="hero-stage-main-grid">
        {featuredApps.map((app) => (
          <article class="hero-stage-main">
            <div class="hero-stage-main-head">
              <div>
                <p class="tile-kicker">{labels.leading}</p>
                <h3>{app.name}</h3>
              </div>
              <span class="badge">{badgeFor(app.status)}</span>
            </div>
            <p class="hero-stage-main-copy">{app.oneLine}</p>
            <div class="hero-stage-main-art" aria-hidden="true">
              <ProductVisual appId={app.id} locale={locale} motif={heroVisualMotif(app.id)} />
            </div>
            <ul class="hero-stage-list">
              {app.bullets.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
            <a class="text-link" href={withBase(getProfilePath(locale, app.id) ?? pathFor(locale, 'apps'))}>
              {t.apps.learnMore}
            </a>
          </article>
        ))}
      </div>
      <div class="hero-stage-side">
        <p class="tile-kicker">{labels.collection}</p>
        {spotlightApps.map((app, index) => (
          <a class="hero-stage-note" href={withBase(getProfilePath(locale, app.id) ?? pathFor(locale, 'apps'))}>
            <div class="hero-stage-note-copy">
              <p class="story-index">{String(index + featuredApps.length + 1).padStart(2, '0')}</p>
              <h3>{app.name}</h3>
              <p>{app.oneLine}</p>
            </div>
            <div class="hero-stage-note-art" aria-hidden="true">
              <ProductVisual appId={app.id} locale={locale} motif={spotlightMotifs[index] ?? 'wave'} />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="shell story" id={t.story.id}>
    <div class="story-head">
      <div class="section-intro story-intro">
        <p class="eyebrow">{labels.story}</p>
        <h2>{t.story.title}</h2>
        <p>{t.story.intro}</p>
      </div>
      <blockquote class="quote story-quote">
        <p class="story-quote-label">{labels.quote}</p>
        <p>{t.story.quote}</p>
      </blockquote>
    </div>
    <div class="story-grid">
      {t.story.blocks.slice(0, 3).map((block, index) => (
        <article class={`story-block ${index === 0 ? 'story-block-featured' : ''}`}>
          <p class="story-index">{String(index + 1).padStart(2, '0')}</p>
          <h3>{block.title}</h3>
          <p>{block.body[0]}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell">
    <div class="section-intro">
      <p class="eyebrow">{labels.principles}</p>
      <h2>{t.principles.title}</h2>
      <p>{t.principles.intro}</p>
    </div>
    <div class="principle-list">
      {t.principles.items.map((item, index) => (
        <article class="principle-row">
          <p class="story-index">{String(index + 1).padStart(2, '0')}</p>
          <div class="principle-row-main">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
          <p class="principle-icon" aria-hidden="true">{item.icon}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell" aria-labelledby="apps-showcase-title">
    <div class="section-intro section-split">
      <div>
        <p class="eyebrow">{labels.products}</p>
        <h2 id="apps-showcase-title">{t.apps.title}</h2>
      </div>
      <p>{t.apps.intro}</p>
    </div>
    <div class="product-list">
      {homeApps.map((app, index) => (
        <article class={`product-row ${featuredIds.has(app.id) ? 'product-row-featured' : ''}`} id={`home-${app.id}`}>
          <div class="product-row-index">
            <span>{String(index + 1).padStart(2, '0')}</span>
          </div>
          <div class="product-row-copy">
            <p class="tile-kicker">{app.nameEn}</p>
            <h3>{app.name}</h3>
            <p class="lead-sm">{app.oneLine}</p>
            <ul class="product-bullets">
              {app.bullets.slice(0, index === 0 ? 3 : 2).map((item) => <li>{item}</li>)}
            </ul>
            <a class="text-link" href={withBase(getProfilePath(locale, app.id) ?? pathFor(locale, 'apps'))}>
              {t.apps.learnMore}
            </a>
          </div>
          <div class="product-row-art" aria-hidden="true">
            <ProductVisual appId={app.id} locale={locale} motif={appMotifs[index] ?? 'wave'} />
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
