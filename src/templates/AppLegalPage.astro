---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProfilePath } from '../i18n/app-profiles';
import { withBase, type Locale } from '../i18n/utils';
import type { AppLegalPageData } from '../i18n/app-legal';

interface Props {
  locale: Locale;
  path: string;
  page: AppLegalPageData;
}

const { locale, path, page } = Astro.props;
const backToApps = locale === 'zh' ? '/apps' : '/en/apps';
const backToProfile = getProfilePath(locale, page.appId);
const backPath = backToProfile ?? backToApps;
const backLabel =
  locale === 'zh'
    ? backToProfile
      ? '返回产品页'
      : '返回应用页'
    : backToProfile
      ? 'Back to Product'
      : 'Back to Apps';
const description =
  locale === 'zh'
    ? `${page.appName} ${page.title}，适用于应用使用与数据处理说明。`
    : `${page.title} for ${page.appName}, including app usage and data handling details.`;
---

<BaseLayout
  title={`${page.title} | ${page.appName} | Flow the Moment`}
  description={description}
  locale={locale}
  path={path}
  noindex={true}
>
  <section class="shell page-hero legal-hero">
    <p class="eyebrow">{page.appName}</p>
    <h1>{page.title}</h1>
    <p class="lead">{locale === 'zh' ? '与该应用相关的隐私与使用条款。' : 'Privacy and usage terms for this app.'}</p>
    <a href={withBase(backPath)} class="text-link">{backLabel}</a>
  </section>

  <section class="shell">
    <article class="card legal-document">
      <div class="legal-document-body">{page.body}</div>
    </article>
  </section>
</BaseLayout>
