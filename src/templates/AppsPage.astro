---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductVisual from '../components/ProductVisual.astro';
import { getCopy } from '../i18n/copy';
import { withBase, type Locale } from '../i18n/utils';
import { getAppLegalLinks } from '../i18n/app-legal';
import { getProfilePath } from '../i18n/app-profiles';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
const t = getCopy(locale);
const motifs: Array<'cat' | 'wave' | 'rings' | 'breathe'> = ['cat', 'breathe', 'wave', 'rings'];
const suiteHighlights = t.apps.items.slice(0, 3);
const releasedIds = new Set(t.apps.items.filter((app) => app.status === 'released').map((app) => app.id));
const siteOrigin = Astro.site?.toString() ?? 'https://flowthemoment.com';
const pageUrl = new URL(withBase(path), siteOrigin).toString();
const pageTitle =
  locale === 'zh'
    ? '应用 | 轻想法与成瘾猫已发布 | Flow the Moment'
    : 'Apps | Light Ideas and Craving Cat are live | Flow the Moment';
const pageDescription =
  locale === 'zh'
    ? '探索 Flow the Moment 的产品：轻想法、成瘾猫、此刻锚、阳光呼吸与稳流。轻想法与成瘾猫已正式上线，其余产品按不同节奏继续生长。'
    : 'Explore Flow the Moment apps: Light Ideas, Craving Cat, Anchor Now, Sunny Breath, and Steady Flow. Light Ideas and Craving Cat are live, while the rest continue to grow at their own pace.';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: t.appsPage.title,
    description: t.appsPage.intro,
    url: pageUrl,
    inLanguage: locale === 'zh' ? 'zh-CN' : 'en'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: t.appsPage.sectionTitle,
    itemListElement: t.apps.items.map((app, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: app.name,
      url: new URL(withBase(getProfilePath(locale, app.id) ?? path), siteOrigin).toString()
    }))
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: locale === 'zh' ? '首页' : 'Home',
        item: new URL(withBase(locale === 'zh' ? '/' : '/en'), siteOrigin).toString()
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: locale === 'zh' ? '应用' : 'Apps',
        item: pageUrl
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: t.appsPage.faqs.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.a
      }
    }))
  }
];
const focusTags =
  locale === 'zh'
    ? ['轻启动', '微结构', '低压专注', '反成瘾']
    : ['Gentle start', 'Micro structure', 'Low-pressure focus', 'Anti-addictive'];
const labels =
  locale === 'zh'
    ? {
        suite: '产品组合',
        faq: '常见问题',
        productPage: '查看产品介绍'
      }
    : {
        suite: 'Product suite',
        faq: 'FAQ',
        productPage: 'View product story'
      };
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={locale}
  path={path}
  jsonLd={jsonLd}
>
  <section class="shell page-hero editorial-page-hero">
    <div>
      <p class="eyebrow">Flow the Moment</p>
      <h1>{t.appsPage.title}</h1>
    </div>
    <div class="page-hero-side page-hero-board">
      <p class="lead">{t.appsPage.intro}</p>
      <div class="tag-row">
        {focusTags.map((tag) => (
          <span class="tag-pill">{tag}</span>
        ))}
      </div>
      <div class="page-hero-notes" aria-label={locale === 'zh' ? '产品摘要' : 'Product summary'}>
        {suiteHighlights.map((app, index) => (
          <a class="page-hero-note" href={withBase(getProfilePath(locale, app.id) ?? '#')}>
            <span class="story-index">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <h3>{app.name}</h3>
              <p>{app.oneLine}</p>
            </div>
            <div class="page-hero-note-art" aria-hidden="true">
              <ProductVisual appId={app.id} locale={locale} motif={motifs[index] ?? 'wave'} />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="shell" aria-labelledby="apps-section-title">
    <div class="section-intro section-split">
      <div>
        <p class="eyebrow">{labels.suite}</p>
        <h2 id="apps-section-title">{t.appsPage.sectionTitle}</h2>
      </div>
    </div>
    <div class="product-list product-list-detailed">
      {t.apps.items.map((app, index) => {
        const legalLinks = getAppLegalLinks(locale, app.id);
        const profilePath = getProfilePath(locale, app.id);
        const badge =
          app.status === 'released'
            ? t.apps.badgeReleased
            : app.status === 'progress'
              ? t.apps.badgeProgress
              : t.apps.badgeComing;
        return (
          <article class={`product-row product-row-detailed ${releasedIds.has(app.id) ? 'product-row-featured' : ''}`} id={app.id}>
            <div class="product-row-index">
              <span>{String(index + 1).padStart(2, '0')}</span>
            </div>
            <div class="product-row-copy">
              <div class="product-row-head">
                <div>
                  <p class="tile-kicker">{app.nameEn}</p>
                  <h3>{app.name}</h3>
                </div>
                <span class="badge">{badge}</span>
              </div>
              <p class="lead-sm">{app.oneLine}</p>
              <p class="product-detail">{app.detail}</p>
              <ul class="product-bullets">
                {app.bullets.slice(0, 3).map((item) => <li>{item}</li>)}
              </ul>
              <div class="product-links">
                {profilePath && (
                  <a class="text-link" href={withBase(profilePath)}>
                    {labels.productPage}
                  </a>
                )}
                {legalLinks && (
                  <>
                    <a class="text-link" href={withBase(legalLinks.privacyPath)}>
                      {legalLinks.privacyLabel}
                    </a>
                    <a class="text-link" href={withBase(legalLinks.termsPath)}>
                      {legalLinks.termsLabel}
                    </a>
                  </>
                )}
              </div>
            </div>
            <div class="product-row-art" aria-hidden="true">
              <ProductVisual appId={app.id} locale={locale} motif={motifs[index] ?? 'wave'} />
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="shell faq" aria-labelledby="faq-title">
    <div class="section-intro section-split">
      <div>
        <p class="eyebrow">{labels.faq}</p>
        <h2 id="faq-title">{t.appsPage.faqTitle}</h2>
      </div>
    </div>
    <div class="faq-list faq-list-editorial">
      {t.appsPage.faqs.map((item, index) => (
        <details class="faq-item">
          <summary>
            <span class="story-index">{String(index + 1).padStart(2, '0')}</span>
            <span>{item.q}</span>
          </summary>
          <p>{item.a}</p>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
