---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAppLegalLinks } from '../i18n/app-legal';
import { getCopy } from '../i18n/copy';
import { withBase, type Locale } from '../i18n/utils';
import type { AppProfile } from '../i18n/app-profiles';
import FlowMotif from '../components/FlowMotif.astro';

interface Props {
  locale: Locale;
  path: string;
  profile: AppProfile;
}

const { locale, path, profile } = Astro.props;
const legalLinks = getAppLegalLinks(locale, profile.appId);
const appSummary = getCopy(locale).apps.items.find((item) => item.id === profile.appId);
const releaseStatus = appSummary?.status;
const backHome = locale === 'zh' ? '/' : '/en';
const backApps = locale === 'zh' ? '/apps' : '/en/apps';
const siteOrigin = Astro.site?.toString() ?? 'https://flowthemoment.com';
const storeUrl = profile.storeUrl;
const pageTitle =
  releaseStatus === 'released'
    ? locale === 'zh'
      ? `${profile.name} ${profile.altName} | 已发布 | Flow the Moment`
      : `${profile.name} | Released | Flow the Moment`
    : `${profile.name} | ${profile.tagline} | Flow the Moment`;
const pageDescription =
  releaseStatus === 'released'
    ? locale === 'zh'
      ? `${profile.name}：${profile.intro} ${storeUrl ? '现已在 App Store 上线。' : '现已正式发布。'}`
      : `${profile.name}: ${profile.intro} ${storeUrl ? 'Now available on the App Store.' : 'Now released.'}`
    : locale === 'zh'
      ? `${profile.name}：${profile.intro}`
      : `${profile.name}: ${profile.intro}`;
const featuredShowcase = profile.showcaseImages?.[0];
const galleryShowcase = profile.showcaseImages?.slice(1) ?? [];
const storeShowcaseGroups = profile.showcaseGroups ?? [];
const shareImage = storeShowcaseGroups[0]?.images[0]?.src ?? featuredShowcase?.src;
const hasVisualShowcase = galleryShowcase.length > 0 || storeShowcaseGroups.length > 0;
const showcaseAnchor = storeShowcaseGroups.length > 0 ? '#profile-store-title' : '#profile-showcase-title';
const openingInHero = profile.opening[0];
const remainingOpening = profile.opening.slice(1);
const applicationCategory = profile.appId === 'light-ideas' ? 'ProductivityApplication' : 'HealthApplication';
const pageUrl = new URL(path, siteOrigin).toString();
const jsonLdImages = [
  featuredShowcase?.src ? new URL(withBase(featuredShowcase.src), siteOrigin).toString() : null,
  ...galleryShowcase.map((image) => new URL(withBase(image.src), siteOrigin).toString()),
  ...storeShowcaseGroups.flatMap((group) => group.images.map((image) => new URL(withBase(image.src), siteOrigin).toString()))
].filter((value): value is string => Boolean(value));
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: profile.name,
    alternateName: profile.altName,
    description: profile.intro,
    applicationCategory,
    mainEntityOfPage: pageUrl,
    url: pageUrl,
    downloadUrl: storeUrl,
    image: jsonLdImages.length > 0 ? jsonLdImages : undefined,
    inLanguage: locale === 'zh' ? 'zh-CN' : 'en'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: locale === 'zh' ? '首页' : 'Home',
        item: new URL(withBase(backHome), siteOrigin).toString()
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: locale === 'zh' ? '应用' : 'Apps',
        item: new URL(withBase(backApps), siteOrigin).toString()
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: profile.name,
        item: pageUrl
      }
    ]
  }
];
const labels =
  locale === 'zh'
    ? {
        overview: '概览',
        principles: '理念',
        flow: '流程',
        capabilities: '支持方式',
        audience: '适合谁',
        visuals: '展示',
        storePreview: 'App Store',
        legal: '隐私与条款'
      }
    : {
        overview: 'Overview',
        principles: 'Principles',
        flow: 'Flow',
        capabilities: 'Support',
        audience: 'Audience',
        visuals: 'Gallery',
        storePreview: 'App Store',
        legal: 'Privacy & Terms'
      };
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale={locale}
  path={path}
  jsonLd={jsonLd}
  ogImage={shareImage}
>
  <section class="shell page-hero product-hero">
    <div class="product-hero-copy">
      <p class="eyebrow">{profile.altName}</p>
      <h1>{profile.name}</h1>
      <p class="lead">{profile.tagline}</p>
      <p class="product-hero-intro">{profile.intro}</p>
      {openingInHero && <p class="hero-intro-extra">{openingInHero}</p>}
      <div class="hero-cta">
        {storeUrl && (
          <a href={storeUrl} class="btn btn-primary" target="_blank" rel="noreferrer">
            {profile.storeLabel ?? (locale === 'zh' ? '前往下载' : 'Download')}
          </a>
        )}
        <a href={withBase(backHome)} class={storeUrl ? 'btn btn-secondary' : 'btn btn-primary'}>
          {locale === 'zh' ? '工作室首页' : 'Studio home'}
        </a>
        <a href={withBase(backApps)} class="btn btn-secondary">{locale === 'zh' ? '全部产品' : 'All products'}</a>
      </div>
      <div class="profile-jump">
        <a href="#profile-principles-title" class="tag-pill">{labels.principles}</a>
        <a href="#profile-flow-title" class="tag-pill">{labels.flow}</a>
        <a href="#profile-features-title" class="tag-pill">{labels.capabilities}</a>
        {hasVisualShowcase && (
          <a href={showcaseAnchor} class="tag-pill">
            {storeShowcaseGroups.length > 0 ? labels.storePreview : labels.visuals}
          </a>
        )}
        {legalLinks && <a href="#profile-legal-title" class="tag-pill">{labels.legal}</a>}
      </div>
      <div class="product-meta-grid">
        {profile.features.slice(0, 3).map((item, index) => (
          <article class="product-meta-card">
            <p class="story-index">{String(index + 1).padStart(2, '0')}</p>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
    <div class="product-hero-visual">
      {profile.appId === 'light-ideas' && featuredShowcase ? (
        <figure class="cover-figure cover-figure-editorial cover-figure-light-ideas">
          <div class="light-ideas-icon-stage">
            <div class="light-ideas-hero-badge">{locale === 'zh' ? '已发布 / App Store' : 'Released / App Store'}</div>
            <div class="light-ideas-icon-shell light-ideas-icon-shell-hero">
              <img src={withBase(featuredShowcase.src)} alt={featuredShowcase.alt} loading="eager" decoding="async" class="light-ideas-icon-image" />
            </div>
            <div class="light-ideas-hero-notes">
              <span>Bubble</span>
              <span>Glass</span>
              <span>{locale === 'zh' ? '本地优先' : 'Local-first'}</span>
            </div>
          </div>
        </figure>
      ) : profile.appId === 'anchor-now' && featuredShowcase ? (
        <figure class="cover-figure cover-figure-editorial cover-figure-anchor">
          <div class="anchor-icon-stage">
            <div class="anchor-hero-badge">{locale === 'zh' ? '开发中 / 低负担介入' : 'In progress / low-load intervention'}</div>
            <img src={withBase(featuredShowcase.src)} alt={featuredShowcase.alt} loading="eager" decoding="async" class="anchor-icon-image" />
            <div class="anchor-hero-notes">
              <span>{locale === 'zh' ? '恐慌' : 'Panic'}</span>
              <span>{locale === 'zh' ? '焦躁' : 'Anxiety'}</span>
              <span>{locale === 'zh' ? '走神' : 'Drift'}</span>
            </div>
          </div>
        </figure>
      ) : profile.appId === 'craving-cat' && featuredShowcase ? (
        <figure class="cover-figure cover-figure-editorial cover-figure-cat-sprite">
          <div class="cat-sprite-stage">
            <div class="cat-hero-badge">{locale === 'zh' ? '已发布 / 温和守护' : 'Released / Gentle protection'}</div>
            <div
              class="cat-sprite-window"
              role="img"
              aria-label={locale === 'zh' ? '成瘾猫动画预览，三花猫在温柔背景里轻轻移动' : 'Craving Cat animated preview, a calico cat moving gently in a soft setting'}
            >
              <div
                class="cat-sprite-sheet"
                style={`--cat-sprite-image: url("${withBase(featuredShowcase.src)}")`}
                aria-hidden="true"
              />
            </div>
            <div class="cat-hero-notes">
              <span>{locale === 'zh' ? '轻边界' : 'Gentle boundaries'}</span>
              <span>{locale === 'zh' ? '猫猫陪伴' : 'Cat companion'}</span>
              <span>{locale === 'zh' ? '一次呼吸' : 'One breath'}</span>
            </div>
          </div>
        </figure>
      ) : featuredShowcase ? (
        <figure class="cover-figure cover-figure-editorial">
          <img src={withBase(featuredShowcase.src)} alt={featuredShowcase.alt} loading="eager" decoding="async" />
        </figure>
      ) : profile.appId === 'anchor-now' ? (
        <div class="cover-fallback cover-fallback-editorial cover-fallback-anchor" aria-hidden="true">
          <div class="anchor-hero-badge">{locale === 'zh' ? '开发中 / 低负担介入' : 'In progress / low-load intervention'}</div>
          <FlowMotif kind="breathe" />
          <div class="anchor-hero-notes">
            <span>{locale === 'zh' ? '恐慌' : 'Panic'}</span>
            <span>{locale === 'zh' ? '焦躁' : 'Anxiety'}</span>
            <span>{locale === 'zh' ? '走神' : 'Drift'}</span>
          </div>
        </div>
      ) : profile.appId === 'craving-cat' ? (
        <div class="cover-fallback cover-fallback-editorial cover-fallback-cat" aria-hidden="true">
          <div class="cat-hero-badge">{locale === 'zh' ? '已发布 / 温和守护' : 'Released / Gentle protection'}</div>
          <FlowMotif kind="cat" />
          <div class="cat-hero-notes">
            <span>{locale === 'zh' ? '轻边界' : 'Gentle boundaries'}</span>
            <span>{locale === 'zh' ? '猫猫陪伴' : 'Cat companion'}</span>
            <span>{locale === 'zh' ? '一次呼吸' : 'One breath'}</span>
          </div>
        </div>
      ) : (
        <div class="cover-fallback cover-fallback-editorial" aria-hidden="true">
          <FlowMotif kind="breathe" />
          <FlowMotif kind="rings" />
        </div>
      )}
    </div>
  </section>

  {remainingOpening.length > 0 && (
    <section class="shell product-overview">
      <div class="section-intro section-split">
        <div>
          <p class="eyebrow">{labels.overview}</p>
        </div>
      </div>
      <div class="editorial-prose">
        {remainingOpening.map((item) => <p>{item}</p>)}
      </div>
    </section>
  )}

  {storeShowcaseGroups.length > 0 && (
    <section class="shell showcase-section showcase-section-store" aria-labelledby="profile-store-title">
      <div class="section-intro section-split">
        <div>
          <p class="eyebrow">{labels.storePreview}</p>
          <h2 id="profile-store-title">{profile.showcaseTitle ?? labels.storePreview}</h2>
        </div>
        {profile.showcaseIntro && <p>{profile.showcaseIntro}</p>}
      </div>
      <div class="store-preview-list">
        {storeShowcaseGroups.map((group, groupIndex) => (
          <article class="store-preview-group">
            <div class="store-preview-group-head">
              <p class="story-index">{String(groupIndex + 1).padStart(2, '0')}</p>
              <div>
                <h3>{group.title}</h3>
                {group.intro && <p>{group.intro}</p>}
              </div>
            </div>
            <div class="promo-grid promo-grid-store">
              {group.images.map((image) => (
                <figure class="promo-card promo-card-store">
                  <img src={withBase(image.src)} alt={image.alt} loading="lazy" decoding="async" />
                  {image.caption && <figcaption>{image.caption}</figcaption>}
                </figure>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="shell" aria-labelledby="profile-principles-title">
    <div class="section-intro section-split">
      <div>
        <p class="eyebrow">{labels.principles}</p>
        <h2 id="profile-principles-title">{profile.principlesTitle}</h2>
      </div>
    </div>
    <div class="editorial-list">
      {profile.principles.map((item, index) => (
        <article class="editorial-row">
          <p class="story-index">{String(index + 1).padStart(2, '0')}</p>
          <div class="editorial-row-main">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="shell" aria-labelledby="profile-flow-title">
    <div class="section-intro section-split">
      <div>
        <p class="eyebrow">{labels.flow}</p>
        <h2 id="profile-flow-title">{profile.flowTitle}</h2>
      </div>
    </div>
    <div class="editorial-list">
      {profile.flow.map((step, index) => (
        <article class="editorial-row">
          <p class="story-index">{String(index + 1).padStart(2, '0')}</p>
          <div class="editorial-row-main">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="shell" aria-labelledby="profile-features-title">
    <div class="feature-columns">
      <section>
        <div class="section-intro">
          <p class="eyebrow">{labels.capabilities}</p>
          <h2 id="profile-features-title">{profile.featureTitle}</h2>
        </div>
        <ul class="editorial-bullet-list">
          {profile.features.map((item) => <li>{item}</li>)}
        </ul>
      </section>
      <section>
        <div class="section-intro">
          <p class="eyebrow">{labels.audience}</p>
          <h2 id="profile-audience-title">{profile.audienceTitle}</h2>
        </div>
        <ul class="editorial-bullet-list">
          {profile.audience.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </div>
  </section>

  {galleryShowcase.length > 0 && (
    <section class="shell showcase-section" aria-labelledby="profile-showcase-title">
      <div class="section-intro section-split">
        <div>
          <p class="eyebrow">{labels.visuals}</p>
          <h2 id="profile-showcase-title" class="showcase-title-visually">{profile.name}</h2>
        </div>
      </div>
      <div class="promo-grid promo-grid-rich">
        {galleryShowcase.map((image) => (
          <figure class="promo-card promo-card-plain">
            <img src={withBase(image.src)} alt={image.alt} loading="lazy" decoding="async" />
          </figure>
        ))}
      </div>
    </section>
  )}

  {legalLinks && (
    <section class="shell" aria-labelledby="profile-legal-title">
      <div class="legal-bar">
        <div>
          <p class="eyebrow">{labels.legal}</p>
          <h2 id="profile-legal-title">{profile.legalTitle}</h2>
          <p>{profile.legalIntro}</p>
        </div>
        <div class="legal-links">
          <a class="btn btn-secondary" href={withBase(legalLinks.privacyPath)}>{profile.legalPrivacyLabel}</a>
          <a class="btn btn-secondary" href={withBase(legalLinks.termsPath)}>{profile.legalTermsLabel}</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
