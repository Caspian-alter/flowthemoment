---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCopy } from '../../i18n/copy';
import { formatDate, withBase } from '../../i18n/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'zh');

  return posts.map((post) => ({
    params: { slug: post.slug.replace(/^zh\//, '') },
    props: { post }
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const t = getCopy('zh');
const { Content, headings } = await render(post);
const tags = post.data.tags ?? [];
const siteOrigin = Astro.site?.toString() ?? 'https://flowthemoment.com';
const postUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const blogUrl = new URL(withBase('/blog'), siteOrigin).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    mainEntityOfPage: postUrl,
    url: postUrl,
    inLanguage: 'zh-CN',
    keywords: tags.join(', '),
    author: {
      '@type': 'Organization',
      name: 'Flow the Moment'
    },
    publisher: {
      '@type': 'Organization',
      name: 'Flow the Moment'
    },
    isPartOf: {
      '@type': 'Blog',
      name: t.blog.title,
      url: blogUrl
    }
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: '首页',
        item: new URL(withBase('/'), siteOrigin).toString()
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: t.blog.title,
        item: blogUrl
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: post.data.title,
        item: postUrl
      }
    ]
  }
];
---

<BaseLayout
  title={`${post.data.title} | ${t.blog.title}`}
  description={post.data.description}
  locale="zh"
  path={Astro.url.pathname}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="shell post-layout">
    <a href={withBase('/blog')} class="text-link back-link">{t.blog.back}</a>
    <header class="post-head">
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <p class="post-date">
        {t.blog.postedOn} {formatDate(post.data.date, 'zh')}
      </p>
      {tags.length > 0 && (
        <p class="tag-list" aria-label={t.blog.tags}>
          {tags.map((tag) => (
            <span>#{tag}</span>
          ))}
        </p>
      )}
    </header>

    {headings.length > 0 && (
      <aside class="card toc">
        <strong>目录</strong>
        <ul>
          {headings.map((heading) => (
            <li>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
