---
import AppLegalPage from '../../../templates/AppLegalPage.astro';
import { getStandaloneLegalStaticPaths, type AppLegalPageData } from '../../../i18n/app-legal';

export function getStaticPaths() {
  return getStandaloneLegalStaticPaths('en', 'light-ideas');
}

interface Props {
  page: AppLegalPageData;
}

const { page } = Astro.props;
---

<AppLegalPage locale="en" path={Astro.url.pathname} page={page} />
