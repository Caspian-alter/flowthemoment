---
import AppLegalPage from '../../templates/AppLegalPage.astro';
import { getStandaloneLegalStaticPaths, type AppLegalPageData } from '../../i18n/app-legal';

export function getStaticPaths() {
  return getStandaloneLegalStaticPaths('zh', 'light-ideas');
}

interface Props {
  page: AppLegalPageData;
}

const { page } = Astro.props;
---

<AppLegalPage locale="zh" path={Astro.url.pathname} page={page} />
