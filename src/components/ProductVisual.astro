---
import { withBase } from '../i18n/utils';
import FlowMotif from './FlowMotif.astro';
import type { Locale } from '../i18n/utils';

interface Props {
  appId: string;
  locale: Locale;
  motif?: 'wave' | 'rings' | 'breathe' | 'cat';
}

const { appId, locale, motif = 'wave' } = Astro.props;
---

{appId === 'anchor-now' ? (
  <div class="product-visual product-visual-anchor" aria-hidden="true">
    <svg viewBox="0 0 260 260" class="anchor-glyph">
      <defs>
        <linearGradient id="anchorStone" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#8ea3a9" />
          <stop offset="50%" stop-color="#71878f" />
          <stop offset="100%" stop-color="#536972" />
        </linearGradient>
        <linearGradient id="anchorMist" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="rgba(255, 247, 237, 0.92)" />
          <stop offset="100%" stop-color="rgba(222, 235, 229, 0.72)" />
        </linearGradient>
      </defs>
      <circle cx="130" cy="132" r="86" fill="url(#anchorMist)" />
      <circle cx="130" cy="132" r="70" fill="none" stroke="rgba(112, 138, 144, 0.22)" stroke-width="2.5" />
      <circle cx="130" cy="76" r="22" fill="none" stroke="url(#anchorStone)" stroke-width="10" />
      <path
        d="M130 96V172M90 148C90 184 106 206 130 206C154 206 170 184 170 148M90 148H74M170 148H186"
        fill="none"
        stroke="url(#anchorStone)"
        stroke-width="12"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M84 154C90 182 108 194 130 194C152 194 170 182 176 154"
        fill="none"
        stroke="rgba(255, 247, 239, 0.66)"
        stroke-width="4"
        stroke-linecap="round"
      />
      <path
        d="M78 144C90 132 102 126 116 126M182 144C170 132 158 126 144 126"
        fill="none"
        stroke="rgba(111, 132, 142, 0.18)"
        stroke-width="3"
        stroke-linecap="round"
      />
      </svg>
  </div>
) : appId === 'light-ideas' ? (
  <div class="product-visual product-visual-light-ideas" aria-hidden="true">
    <div class="light-ideas-aura" />
    <div class="light-ideas-icon-shell">
      <img src={withBase('/images/light-ideas/icon.png')} alt="" loading="lazy" decoding="async" class="light-ideas-icon-image" />
    </div>
    <div class="light-ideas-note-row">
      <span>{locale === 'zh' ? '已发布' : 'Released'}</span>
      <span>{locale === 'zh' ? 'Bubble / Glass' : 'Bubble / Glass'}</span>
    </div>
  </div>
) : appId === 'craving-cat' ? (
  <div class="product-visual product-visual-cat" aria-hidden="true">
    <div class="cat-portrait-aura" />
    <img
      src={withBase('/images/craving-cat/0-cat.png')}
      alt=""
      loading="lazy"
      decoding="async"
      class="product-visual-cat-image"
    />
  </div>
) : (
  <div class="product-visual product-visual-motif" aria-hidden="true">
    <FlowMotif kind={motif} />
  </div>
)}
