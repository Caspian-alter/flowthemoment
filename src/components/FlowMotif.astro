---
interface Props {
  kind?: 'wave' | 'rings' | 'breathe' | 'cat';
}

const { kind = 'wave' } = Astro.props;
---

{kind === 'wave' && (
  <svg class="motif" viewBox="0 0 240 120" aria-hidden="true">
    <defs>
      <linearGradient id="waveGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="var(--accent-soft)" />
        <stop offset="100%" stop-color="var(--accent)" />
      </linearGradient>
    </defs>
    <path d="M10 70C42 30 66 96 110 58C153 22 185 90 230 52" fill="none" stroke="url(#waveGrad)" stroke-width="6" stroke-linecap="round" />
    <path d="M10 90C42 50 66 116 110 78C153 42 185 110 230 72" fill="none" stroke="var(--accent-soft)" stroke-width="3" stroke-linecap="round" />
  </svg>
)}

{kind === 'rings' && (
  <svg class="motif" viewBox="0 0 160 160" aria-hidden="true">
    <circle cx="80" cy="80" r="24" fill="none" stroke="var(--accent)" stroke-width="4" />
    <circle cx="80" cy="80" r="42" fill="none" stroke="var(--accent-soft)" stroke-width="3" />
    <circle cx="80" cy="80" r="62" fill="none" stroke="var(--line-strong)" stroke-width="2" />
  </svg>
)}

{kind === 'breathe' && (
  <svg class="motif" viewBox="0 0 200 120" aria-hidden="true">
    <ellipse cx="68" cy="62" rx="54" ry="36" fill="var(--accent-soft)" opacity="0.55" />
    <ellipse cx="132" cy="62" rx="54" ry="36" fill="var(--accent)" opacity="0.35" />
    <path d="M38 96C78 68 122 68 162 96" fill="none" stroke="var(--accent-deep)" stroke-width="3" stroke-linecap="round" />
  </svg>
)}

{kind === 'cat' && (
  <svg class="motif motif-cat" viewBox="0 0 240 200" aria-hidden="true">
    <defs>
      <linearGradient id="catBodyGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#f4c9a8" />
        <stop offset="100%" stop-color="#d89068" />
      </linearGradient>
    </defs>
    <circle cx="120" cy="92" r="54" fill="url(#catBodyGrad)" />
    <path d="M82 58L100 24L112 58Z" fill="#d89068" />
    <path d="M128 58L140 24L158 58Z" fill="#d89068" />
    <ellipse cx="120" cy="108" rx="34" ry="22" fill="#fff7ef" opacity="0.9" />
    <circle cx="102" cy="88" r="7" fill="#2c3340" />
    <circle cx="138" cy="88" r="7" fill="#2c3340" />
    <path d="M120 98L113 108H127Z" fill="#c88469" />
    <path d="M108 120C112 126 117 128 120 128C123 128 128 126 132 120" fill="none" stroke="#2c3340" stroke-width="3.4" stroke-linecap="round" />
    <path d="M90 106C72 102 62 102 46 106" fill="none" stroke="#2c3340" stroke-width="2.6" stroke-linecap="round" opacity="0.55" />
    <path d="M90 114C72 116 62 118 46 124" fill="none" stroke="#2c3340" stroke-width="2.6" stroke-linecap="round" opacity="0.55" />
    <path d="M150 106C168 102 178 102 194 106" fill="none" stroke="#2c3340" stroke-width="2.6" stroke-linecap="round" opacity="0.55" />
    <path d="M150 114C168 116 178 118 194 124" fill="none" stroke="#2c3340" stroke-width="2.6" stroke-linecap="round" opacity="0.55" />
    <circle cx="188" cy="56" r="20" fill="var(--accent-soft)" opacity="0.7" />
    <rect x="180" y="48" width="6" height="16" rx="3" fill="var(--accent-deep)" />
    <rect x="190" y="48" width="6" height="16" rx="3" fill="var(--accent-deep)" />
    <path d="M170 152C204 126 222 140 216 174C196 186 182 174 170 152Z" fill="none" stroke="#d6a07b" stroke-width="14" stroke-linecap="round" stroke-linejoin="round" opacity="0.85" />
  </svg>
)}
